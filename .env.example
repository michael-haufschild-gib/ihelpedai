# ihelped.ai — example env. Copy to .env.local for local dev.
# Runtime
NODE_ENV=development
PORT=3001
PUBLIC_URL=http://localhost:5173

# Security
IP_HASH_SALT=change-me-in-prod
ADMIN_SESSION_SECRET=change-me-in-prod

# Mailer
MAILER=file              # file | smtp
SMTP_URL=                # required when MAILER=smtp
MAIL_FROM=noreply@ihelped.ai

# Store
STORE=sqlite             # sqlite | mysql
SQLITE_PATH=./dev.db
MYSQL_URL=               # required when STORE=mysql

# Search
SEARCH=sql               # sql | meili
MEILI_URL=
MEILI_KEY=

# Rate limit
RATE_LIMIT=memory        # memory | redis
REDIS_URL=

# Dev-only affordance: multiplier applied to all rate limits in dev (local testing).
# Default 10 in dev, 1 in production.
DEV_RATE_MULTIPLIER=10
