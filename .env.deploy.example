# ihelped.ai — deploy environment (committed template).
# Copy to .env.deploy (gitignored) and tweak. deploy/*.sh scripts source it.

# SSH alias or user@host reachable from your workstation.
IHELPED_DEPLOY_HOST=calmerapy

# Remote install root on the server.
IHELPED_DEPLOY_ROOT=/var/www/ihelped.ai

# systemd reads this file for runtime env.
IHELPED_REMOTE_ENV_FILE=/etc/ihelped.env

# Override to skip the HTTPS health check during the pre-TLS phase. After
# certbot has run and DNS is live, unset this to exercise the full nginx path.
# IHELPED_HEALTH_URL=http://127.0.0.1:3001/api/health
